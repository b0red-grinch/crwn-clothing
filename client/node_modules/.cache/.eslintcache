ector';\r\n\r\nimport { auth } from '../../firebase/firebase.utils';\r\nimport { signOutStart } from '../../redux/user/user.actions';\r\n\r\nimport './header.styles.scss';\r\nimport { HeaderContainer, LogoContainer, OptionsContainer, OptionLink} from './header.styles';\r\n\r\nconst Header = ({ currentUser, hidden, signOutStart }) => {\r\n \r\n    return (\r\n    <HeaderContainer>\r\n        <LogoContainer to=\"/\">\r\n            <Logo> </Logo>\r\n        </LogoContainer>\r\n        <OptionsContainer>\r\n            <OptionLink to='shop'>\r\n                SHOP\r\n            </OptionLink>\r\n            <OptionLink  to='contact'>\r\n                CONTACT\r\n            </OptionLink>\r\n            {\r\n                currentUser ? (\r\n                <OptionLink as='div'  onClick={signOutStart}> \r\n                    SIGN OUT  \r\n                </OptionLink>\r\n                ) : (\r\n                <OptionLink  to='/signIn'>\r\n                    SIGN IN\r\n                </OptionLink>\r\n                )\r\n            }\r\n            <CartIcon />\r\n        </OptionsContainer>\r\n        { hidden ? null : <CartDropDown /> }\r\n    </HeaderContainer>\r\n)\r\n        }\r\n\r\nconst mapDispatchToProps = (dispatch) => ({\r\n    signOutStart: () => dispatch(signOutStart())\r\n})\r\n\r\nconst mapStateToProps = createStructuredSelector({\r\n    currentUser: selectCurrentUser,\r\n    hidden: selectCartHidden\r\n});\r\n\r\nexport default connect(mapStateToProps, mapDispatchToProps)(Header);","C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\redux\\shop\\shop.saga.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\redux\\user\\user.saga.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\redux\\shop\\shop.reducer.js",["273"],"import SHOP_DATA from \"./shop.data\";\r\nimport shopActionTypes from \"./shop.types\";\r\n\r\nconst INITIAL_STATE = {\r\n    collections: null,\r\n    isLoading: true\r\n};\r\n\r\nconst shopReducer = (state=INITIAL_STATE, action) => {\r\n    switch (action.type) {\r\n        case shopActionTypes.FETCH_COLLECTION_SUCCESS:\r\n            return {\r\n                ...state,\r\n                collections: action.payload,\r\n                isLoading: false\r\n            }\r\n        default:\r\n            return state;\r\n    }\r\n};\r\n\r\n\r\nexport default shopReducer;","C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\redux\\user\\user.types.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\redux\\cart\\cart.saga.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\redux\\user\\user.reducer.jsx",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\redux\\cart\\cart.reducer.jsx",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\redux\\directory\\directory.reducer.jsx",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\redux\\shop\\shop.actions.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\pages\\homepage\\homepage.styles.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\pages\\checkout\\checkout.styles.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\pages\\collection\\collection.styles.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\components\\collection-overview\\collection-overview.styles.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\components\\header\\header.styles.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\components\\directory-menu\\directory-menu.component.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\components\\checkout-item\\checkout-item.component.js",[],"C:\\Users\\USER\\Downloads\\WORK\\React\\crwn-clothing\\client\\src\\firebase\\firebase.utils.js",[],"C:\\Users\\US